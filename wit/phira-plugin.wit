// Phira-mp+ Plugin ABI v2 — WIT / Component Model
//
// This is the typed replacement for the current JSON-memory bridge (abi-json-v1).
// Target: abi-wit-v2
//
// Migration:
//   1. Define WIT interfaces matching the current JSON ABI (this file)
//   2. Generate host bindings with wasmtime::component::bindgen!
//   3. Implement host side (wasm_host.rs → typed WIT imports)
//   4. Update guest SDK (phira-mp-plus-sdk) to use WIT exports
//   5. Dual-support both ABIs during transition
//   6. Remove JSON bridge after all plugins migrate

package phira:plugin@0.2.0;

/// Core data types shared between host and guest.
interface phira-types {
    /// Touch event point from gameplay.
    record touch-event-point {
        time: f32,
        finger: u32,
        x: f32,
        y: f32,
    }

    /// Judge event item from gameplay.
    record judge-event-item {
        time: f32,
        line-id: u32,
        note-id: u32,
        judgement: string,
    }

    /// Plugin metadata returned by get-info.
    record plugin-info {
        name: string,
        version: string,
        author: string,
        description: string,
    }

    /// Result of an HTTP request made by the plugin.
    record http-response {
        status: u16,
        headers: list<tuple<string, string>>,
        body: list<u8>,
    }

    /// Player record data for GameEnd event.
    record game-end-record {
        user-id: u32,
        user-name: string,
        score: u32,
        accuracy: float32,
        perfect: u32,
        good: u32,
        bad: u32,
        miss: u32,
        max-combo: u32,
        full-combo: bool,
    }

    /// A generic JSON value. Used for plugin API arguments/results
    /// until the WIT interface is fully specialized.
    variant json-value {
        null,
        flag(bool),
        integer(s64),
        float(float64),
        text(string),
        array(list<json-value>),
        object(list<tuple<string, json-value>>),
    }

    /// Host API result: either a JSON value or an error string.
    variant api-result {
        ok(json-value),
        error(string),
    }
}

/// Host functions available to WASM plugins.
interface phira-host {
    use phira-types.{touch-event-point, judge-event-item, plugin-info, http-response, json-value, api-result, game-end-record};

    /// Log a message from the plugin.
    log: func(level: string, message: string);

    /// Generate a UUID v4 string.
    generate-uuid: func() -> string;

    /// Get current timestamp in milliseconds.
    current-time-ms: func() -> u64;

    /// Call a server API method. Matches the host's ServerStateQuery interface.
    api-call: func(method: string, args: list<json-value>) -> api-result;

    /// Send a chat message as system (user-id 0) or as a specific user.
    send-chat: func(user-id: u32, message: string);

    /// Make an outbound HTTP request (sandboxed by WasmRuntimeConfig).
    http-request: func(url: string, method: string, headers: list<tuple<string, string>>, body: list<u8>) -> result<http-response, string>;
}

/// Events the host sends to plugins.
interface phira-events {
    use phira-types.{touch-event-point, judge-event-item, game-end-record};

    /// All event types the host can dispatch to plugins.
    variant plugin-event {
        user-connect(user-id: u32, user-name: string, user-ip: string),
        user-disconnect(user-id: u32, user-name: string),
        room-create(user-id: u32, room-id: string),
        room-join(user-id: u32, room-id: string, is-monitor: bool),
        room-leave(user-id: u32, room-id: string),
        room-modify(user-id: u32, room-id: string, data: string),
        game-start(user-id: u32, room-id: string),
        game-end(user-id: u32, room-id: string, record: game-end-record),
        player-touches(user-id: u32, room-id: string, data: list<touch-event-point>),
        player-judges(user-id: u32, room-id: string, data: list<judge-event-item>),
        round-complete(room-id: string, chart-id: u32, chart-name: string),
    }
}

/// User and room data query APIs available to plugins.
interface phira-query {
    use phira-types.{json-value, api-result};

    /// Get user basic info (id, name, language, monitor status).
    get-user: func(user-id: u32) -> api-result;

    /// Get user's extra extension data by key.
    get-user-extra: func(user-id: u32, key: string) -> api-result;

    /// Set user's extra extension data.
    set-user-extra: func(user-id: u32, key: string, value: string) -> api-result;

    /// Get room basic info (id, host, players, state, endpoint).
    get-room: func(room-id: string) -> api-result;

    /// Get room's extra extension data by key.
    get-room-extra: func(room-id: string, key: string) -> api-result;

    /// List all active room IDs.
    list-rooms: func() -> api-result;

    /// List online user IDs.
    list-online-users: func() -> api-result;

    /// Check if a user is currently online.
    is-user-online: func(user-id: u32) -> bool;
}

/// Room management operations.
interface phira-room-mgmt {
    use phira-types.{api-result};

    /// Create an empty persistent room with optional endpoint override.
    create-empty-room: func(room-id: string, endpoint: option<string>) -> api-result;

    /// Kick a user from a room.
    kick-from-room: func(room-id: string, target-id: u32) -> api-result;

    /// Transfer host to another user in the room.
    transfer-host: func(room-id: string, target-id: u32) -> api-result;

    /// Set room host (none = system ? host).
    set-host: func(room-id: string, target-id: option<u32>) -> api-result;

    /// Lock or unlock a room.
    set-room-lock: func(room-id: string, locked: bool) -> api-result;

    /// Hide or unhide a room (hidden rooms excluded from Web API).
    set-room-hidden: func(room-id: string, hidden: bool) -> api-result;

    /// Close / disband a room.
    close-room: func(room-id: string) -> api-result;

    /// Set room-level phira_api_endpoint override.
    set-room-phira-api-endpoint: func(room-id: string, endpoint: option<string>) -> api-result;
}

/// User management and moderation.
interface phira-user-mgmt {
    use phira-types.{api-result};

    /// Kick a user from the server.
    kick-user: func(user-id: u32, reason: string) -> api-result;

    /// Ban a user.
    ban-user: func(user-id: u32, reason: string) -> api-result;

    /// Unban a user.
    unban-user: func(user-id: u32) -> api-result;

    /// List banned users.
    get-ban-list: func() -> api-result;

    /// Check if a user is banned.
    is-banned: func(user-id: u32) -> bool;
}

/// Messaging — send messages and broadcast.
interface phira-messaging {
    use phira-types.{api-result};

    /// Send a direct message to a specific user.
    send-to-user: func(user-id: u32, message: string) -> api-result;

    /// Broadcast a message to all users in a room.
    send-to-room: func(room-id: string, message: string) -> api-result;

    /// Broadcast a message to all connected users.
    send-to-all: func(message: string) -> api-result;
}

/// Persistence read API — incremental event/snapshot queries.
interface phira-persistence {
    use phira-types.{api-result};

    /// Query sequential events since a sequence number.
    query-events: func(since-sequence: u64, limit: u32, kind: option<string>, room-id: option<string>, user-id: option<u32>) -> api-result;

    /// Query room snapshots since a sequence number.
    query-room-snapshots: func(since-sequence: u64, limit: u32) -> api-result;

    /// Query touch batches.
    query-touches: func(since-sequence: u64, limit: u32, round-uuid: option<string>, player-id: option<u32>) -> api-result;

    /// Query judge batches.
    query-judges: func(since-sequence: u64, limit: u32, round-uuid: option<string>, player-id: option<u32>) -> api-result;

    /// Get playtime for a user.
    get-playtime: func(user-id: u32) -> api-result;

    /// Get top playtime ranking.
    top-playtime: func(limit: u32) -> api-result;
}

/// Admin Phira ID configuration.
interface phira-admin {
    use phira-types.{api-result};

    /// List admin Phira IDs.
    list-admin-ids: func() -> api-result;

    /// Check if a user is an admin.
    is-admin: func(user-id: u32) -> bool;

    /// Add an admin Phira ID.
    add-admin-id: func(user-id: u32) -> api-result;

    /// Remove an admin Phira ID.
    remove-admin-id: func(user-id: u32) -> api-result;

    /// Set the full admin ID list.
    set-admin-ids: func(ids: list<u32>) -> api-result;
}

/// Plugin configuration (key-value, JSON, per-plugin config.json on disk).
interface phira-config {
    use phira-types.{api-result};

    /// Get a configuration value by key path (e.g. "api.timeout").
    /// Returns null if the key does not exist.
    get-config: func(key-path: string) -> api-result;

    /// Set a configuration value by key path.
    /// Persisted to data/plugins/<name>/config.json.
    set-config: func(key-path: string, value: string) -> api-result;

    /// List all keys at the given prefix.
    list-config: func(prefix: string) -> api-result;

    /// Reload config.json from disk.
    reload-config: func() -> api-result;

    /// Poll for config changes since a version counter.
    poll-config-changes: func(since-version: u64) -> api-result;
}

/// Simulation management.
interface phira-simulation {
    use phira-types.{api-result};

    /// Get current simulation status.
    status: func() -> api-result;

    /// Start a simulation run.
    run: func(preset: string, users: option<u32>, rooms: option<u32>, duration: option<u32>) -> api-result;

    /// Stop the current simulation run.
    stop: func() -> api-result;

    /// Clean up all simulation data.
    cleanup: func() -> api-result;
}

/// Runtime diagnostics.
interface phira-runtime {
    use phira-types.{api-result};

    /// Get runtime v2 status summary (event bus, worker, registry).
    status: func() -> api-result;

    /// Get EventBus stats.
    events: func(limit: option<u32>) -> api-result;

    /// Get registered command stats.
    commands: func() -> api-result;
}

/// The plugin world — what a WASM plugin component must export
/// and what the host provides.
world phira-plugin-v2 {
    import phira-host;
    import phira-events;
    import phira-query;
    import phira-room-mgmt;
    import phira-user-mgmt;
    import phira-messaging;
    import phira-persistence;
    import phira-admin;
    import phira-config;
    import phira-simulation;
    import phira-runtime;

    export init: func() -> result<_, string>;
    export get-info: func() -> plugin-info;
    export cleanup: func();

    /// Called when the host dispatches an event to this plugin.
    /// Returns ok(true) if the plugin handled the event.
    export on-event: func(event: plugin-event) -> result<bool, string>;

    /// Called when something invokes a plugin-exposed API method.
    /// Returns the JSON result or error.
    export on-api: func(method: string, args: list<json-value>) -> api-result;
}
